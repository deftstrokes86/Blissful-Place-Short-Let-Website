{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp-test-build",
    "module": "commonjs",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "incremental": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src/server/booking/**/*.ts",
    "src/server/jobs/**/*.ts",
    "src/server/payments/**/*.ts",
    "src/lib/booking-state-machine.ts",
    "src/lib/booking-pricing.ts",
    "src/types/booking.ts",
    "src/types/booking-backend.ts"
  ]
}

