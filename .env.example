# Local Prisma CLI note:
# Put DATABASE_URL in the repo root .env so raw Prisma commands and npm Prisma scripts can see it.
# Keep .env.local for app/runtime-only overrides or temporary developer-specific changes.
# Preferred local Prisma-ready Supabase direct connection:
DATABASE_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"

# Optional only for local Prisma migrate workflows that need a separate shadow database.
# Leave blank unless you intentionally run `prisma migrate dev` against a dedicated dev database.
# It is not part of the normal `npm run prisma:push` workflow.
SHADOW_DATABASE_URL=""

# Alternative for environments where the direct host is not reachable:
# Supabase Supavisor session pooler on port 5432, still with sslmode=require.
# Example only:
# DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require"

# If you intentionally switch runtime traffic to the Supavisor transaction pooler on port 6543,
# add `pgbouncer=true` to DATABASE_URL and keep a separate direct or session connection available
# for Prisma CLI workflows such as migrate, db pull, or db push.
# Example only:
# DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Optional: tune environment-specific behavior
NODE_ENV="development"

# Base app URL used to derive callback URLs when explicit redirects are not provided
SITE_URL="http://localhost:3000"

# Flutterwave server-side integration (website payment branch)
# Server secret key: required for checkout creation + transaction verification
FLW_SECRET_KEY="FLWSECK_TEST-xxxxxxxxxxxxxxxx"

# Optional public key for future frontend display/config needs
FLW_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxxxxxxxxxx"

# Webhook secret/hash configured in Flutterwave dashboard
FLW_WEBHOOK_SECRET_HASH="your_flutterwave_webhook_secret_hash"

# Optional explicit callback URL (otherwise derived from SITE_URL + /api/payments/website/callback)
FLW_REDIRECT_URL="http://localhost:3000/api/payments/website/callback"

# Optional API base override (defaults to https://api.flutterwave.com/v3)
FLW_API_BASE_URL="https://api.flutterwave.com/v3"

# Notification delivery configuration (server-side only)
# Safe default is internal-only delivery until a real email provider is wired.
NOTIFICATION_EMAIL_ENABLED="false"

# In non-production environments, email delivery stays off unless this is also true.
NOTIFICATION_ALLOW_NON_PROD_EMAIL="false"

# Sender identity used by server-side email delivery providers.
NOTIFICATION_SENDER_NAME="Blissful Place Reservations"
NOTIFICATION_SENDER_EMAIL="no-reply@example.test"

# Staff notification routing
NOTIFICATION_STAFF_INTERNAL_RECIPIENT="ops:bookings"
NOTIFICATION_STAFF_RECIPIENT_EMAILS="ops@example.test"

# Bootstrap first internal admin/staff user (one-time, internal only)
# Run: npm run auth:bootstrap
# This now uses the same Prisma + DATABASE_URL path as the main auth runtime.
# Keep disabled by default; enable only for controlled setup runs.
AUTH_BOOTSTRAP_ENABLED="false"
AUTH_BOOTSTRAP_EMAIL="admin@example.test"
AUTH_BOOTSTRAP_PASSWORD="change-this-to-a-strong-password"
AUTH_BOOTSTRAP_ROLE="admin"

# Payload CMS internal management layer
# Mounted in app at /cms with REST API at /cms/api
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Optional legacy Payload-only override.
# Leave blank in normal Hostinger/Supabase setups so Payload reuses DATABASE_URL.
# Only set this when Payload must temporarily point at a different Postgres database during a controlled migration.
PAYLOAD_DATABASE_URL=""

# Emergency escape hatch only for legacy production setups with intentional persistent disk.
# This is not part of the normal Hostinger + Supabase Postgres path.
PAYLOAD_ALLOW_PRODUCTION_SQLITE="false"

# Optional override for Payload schema sync.
# In development, schema push defaults to enabled to avoid collection-drift runtime errors.
# In production, keep this "false" unless running a controlled migration window.
PAYLOAD_AUTO_PUSH_SCHEMA="true"

# Optional Payload media object storage via Supabase Storage.
# Leave these blank in local development to keep blog-media uploads on the local filesystem.
# In production, set these to move blog-media uploads to persistent Supabase Storage.
PAYLOAD_MEDIA_SUPABASE_BUCKET="blog-media"
PAYLOAD_MEDIA_SUPABASE_REGION="your-storage-region"
PAYLOAD_MEDIA_SUPABASE_PROJECT_REF="your-project-ref"

# Optional explicit S3 endpoint override.
# Leave blank when PAYLOAD_MEDIA_SUPABASE_PROJECT_REF is set and the app will derive
# https://<project-ref>.storage.supabase.co/storage/v1/s3 automatically.
PAYLOAD_MEDIA_SUPABASE_ENDPOINT=""

# Generate these server-side S3 credentials in Supabase Storage settings.
PAYLOAD_MEDIA_SUPABASE_ACCESS_KEY_ID="replace-with-supabase-storage-access-key"
PAYLOAD_MEDIA_SUPABASE_SECRET_ACCESS_KEY="replace-with-supabase-storage-secret-key"
PAYLOAD_MEDIA_SUPABASE_FORCE_PATH_STYLE="true"

# Emergency escape hatch only for production environments with intentional persistent disk for uploads.
PAYLOAD_ALLOW_PRODUCTION_LOCAL_MEDIA="false"

# Hostinger note: after changing any production env var, use Settings and redeploy so the running app picks it up.
