# Blissful Place environment template
# Use the repo root `.env` for shared server-side defaults and Prisma CLI commands.
# Use `.env.local` only for local Next.js/runtime-only overrides after that.
# For the Hostinger production checklist, start with docs/production-env-setup.md.

# Core app runtime
NODE_ENV="development"
SITE_URL="http://localhost:3000"

# Prisma / Supabase Postgres
# DATABASE_URL is required for Prisma and for the main server runtime.
# Supabase Postgres URLs must keep ?sslmode=require in the query string.
# Preferred direct connection for local development:
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# Alternative when the direct host is not reachable from your machine:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# If you intentionally use the Supabase transaction pooler on 6543,
# append pgbouncer=true and keep a direct or session connection available for Prisma CLI workflows.
# Example only:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Optional only for local Prisma migrate workflows that need a separate shadow database.
# It is not part of the normal `npm run prisma:push` workflow.
SHADOW_DATABASE_URL=""

# Payload CMS runtime
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Payload CMS database
# Public /blog and /blog/[slug] reads depend on this same Payload database connection.
# Payload uses PAYLOAD_DATABASE_URL when it is set; otherwise it falls back to DATABASE_URL.
# For Supabase Postgres, the selected connection string must include ?sslmode=require.
# Normal setup: leave PAYLOAD_DATABASE_URL blank so Payload uses the same DATABASE_URL as Prisma.
# If you intentionally set PAYLOAD_DATABASE_URL in a normal deployment, it should usually be identical to DATABASE_URL.
# Only use a different value during a controlled migration or when you deliberately want a local CMS-only SQLite sandbox.
PAYLOAD_DATABASE_URL=""

# Optional local CMS-only SQLite sandbox for non-production use:
# PAYLOAD_DATABASE_URL="file:./.data/payload.db"
# Keep DATABASE_URL pointed at Supabase Postgres even when using that local Payload-only override.

# In development, Payload schema push defaults to enabled.
# In production, keep this false unless you are in a controlled migration window.
PAYLOAD_AUTO_PUSH_SCHEMA="true"

# Payload media / Supabase Storage
# Leave these blank in local development to keep blog-media uploads on the local filesystem.
# In Hostinger production, set them to move blog-media uploads to persistent Supabase Storage.
PAYLOAD_MEDIA_SUPABASE_BUCKET="blog-media"
PAYLOAD_MEDIA_SUPABASE_REGION="your-storage-region"
PAYLOAD_MEDIA_SUPABASE_PROJECT_REF="your-project-ref"

# Leave blank when PAYLOAD_MEDIA_SUPABASE_PROJECT_REF is set and the app should derive
# https://<project-ref>.storage.supabase.co/storage/v1/s3 automatically.
PAYLOAD_MEDIA_SUPABASE_ENDPOINT=""

# Generate these server-side S3 credentials in Supabase Storage settings.
PAYLOAD_MEDIA_SUPABASE_ACCESS_KEY_ID="replace-with-supabase-storage-access-key"
PAYLOAD_MEDIA_SUPABASE_SECRET_ACCESS_KEY="replace-with-supabase-storage-secret-key"
PAYLOAD_MEDIA_SUPABASE_FORCE_PATH_STYLE="true"

# In normal production, keep local media storage disabled.
PAYLOAD_ALLOW_PRODUCTION_LOCAL_MEDIA="false"

# Payments / Flutterwave
FLW_SECRET_KEY="FLWSECK_TEST-xxxxxxxxxxxxxxxx"
FLW_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxxxxxxxxxx"
FLW_WEBHOOK_SECRET_HASH="your_flutterwave_webhook_secret_hash"
FLW_REDIRECT_URL="http://localhost:3000/api/payments/website/callback"
FLW_API_BASE_URL="https://api.flutterwave.com/v3"

# Notifications / email delivery
NOTIFICATION_EMAIL_ENABLED="false"
NOTIFICATION_ALLOW_NON_PROD_EMAIL="false"
NOTIFICATION_SENDER_NAME="Blissful Place Reservations"
NOTIFICATION_SENDER_EMAIL="no-reply@example.test"
NOTIFICATION_STAFF_INTERNAL_RECIPIENT="ops:bookings"
NOTIFICATION_STAFF_RECIPIENT_EMAILS="ops@example.test"

# Auth bootstrap (one-time internal setup)
# Run: npm run auth:bootstrap
AUTH_BOOTSTRAP_ENABLED="false"
AUTH_BOOTSTRAP_EMAIL="admin@example.test"
AUTH_BOOTSTRAP_PASSWORD="change-this-to-a-strong-password"
AUTH_BOOTSTRAP_ROLE="admin"

# Hostinger note: after changing any production env var, use Settings and redeploy so the running app picks it up.


