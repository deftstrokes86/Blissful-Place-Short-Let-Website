NODE_ENV="production"
SITE_URL="https://your-production-domain.example"
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Primary persistent Postgres database for Prisma and Payload CMS.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# Optional Payload override. Leave blank to reuse DATABASE_URL in production.
PAYLOAD_DATABASE_URL=""

# Never allow ephemeral SQLite in production unless your host has intentional persistent disk.
PAYLOAD_ALLOW_PRODUCTION_SQLITE="false"

# Keep schema auto-push off in production unless you are in a controlled migration window.
PAYLOAD_AUTO_PUSH_SCHEMA="false"

# Persistent object storage for blog-media uploads.
PAYLOAD_MEDIA_S3_BUCKET="your-media-bucket"
PAYLOAD_MEDIA_S3_REGION="eu-west-1"

# Leave blank on AWS to use https://s3.<region>.amazonaws.com.
# For S3-compatible providers, set the full endpoint explicitly.
PAYLOAD_MEDIA_S3_ENDPOINT=""
PAYLOAD_MEDIA_S3_ACCESS_KEY_ID="replace-with-access-key"
PAYLOAD_MEDIA_S3_SECRET_ACCESS_KEY="replace-with-secret-key"
PAYLOAD_MEDIA_S3_FORCE_PATH_STYLE="true"

# Never allow ephemeral local media storage in production unless your host has intentional persistent disk.
PAYLOAD_ALLOW_PRODUCTION_LOCAL_MEDIA="false"
