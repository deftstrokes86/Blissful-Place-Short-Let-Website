NODE_ENV="production"
SITE_URL="https://your-production-domain.example"
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Hostinger production deploy note:
# 1. Add or update these values in your Node.js app environment variables.
# 2. Save the changes.
# 3. Use Settings and redeploy so the running app picks up the new configuration.

# Canonical server-side database URL for Prisma and, by default, Payload CMS.
# Recommended default for Hostinger: Supabase Supavisor session pooler on port 5432.
# If you have already verified direct database connectivity from Hostinger, you may use
# the direct db.<project-ref>.supabase.co:5432 connection instead.
DATABASE_URL="postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require"

# Optional only for local Prisma migrate workflows that need a separate shadow database.
# Most production environments should leave this blank.
SHADOW_DATABASE_URL=""

# Optional legacy Payload override. Leave blank to keep Payload on the same DATABASE_URL.
PAYLOAD_DATABASE_URL=""

# Never allow ephemeral SQLite in production unless your host has intentional persistent disk.
PAYLOAD_ALLOW_PRODUCTION_SQLITE="false"

# Keep schema auto-push off in production unless you are in a controlled migration window.
PAYLOAD_AUTO_PUSH_SCHEMA="false"

# If you intentionally move runtime traffic to the Supavisor transaction pooler on port 6543,
# append pgbouncer=true to DATABASE_URL and keep a separate direct or session connection available
# for Prisma CLI workflows such as migrate deploy.

# Persistent Supabase Storage for blog-media uploads.
PAYLOAD_MEDIA_SUPABASE_BUCKET="blog-media"
PAYLOAD_MEDIA_SUPABASE_REGION="your-storage-region"
PAYLOAD_MEDIA_SUPABASE_PROJECT_REF="your-project-ref"

# Leave blank to derive https://<project-ref>.storage.supabase.co/storage/v1/s3 automatically.
PAYLOAD_MEDIA_SUPABASE_ENDPOINT=""

# Generate these server-side S3 credentials in Supabase Storage settings.
PAYLOAD_MEDIA_SUPABASE_ACCESS_KEY_ID="replace-with-supabase-storage-access-key"
PAYLOAD_MEDIA_SUPABASE_SECRET_ACCESS_KEY="replace-with-supabase-storage-secret-key"
PAYLOAD_MEDIA_SUPABASE_FORCE_PATH_STYLE="true"

# Never allow ephemeral local media storage in production unless your host has intentional persistent disk.
PAYLOAD_ALLOW_PRODUCTION_LOCAL_MEDIA="false"
