NODE_ENV="production"
SITE_URL="https://your-production-domain.example"
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Primary persistent Postgres database for Prisma and Payload CMS.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# Optional Payload override. Leave blank to reuse DATABASE_URL in production.
PAYLOAD_DATABASE_URL=""

# Never allow ephemeral SQLite in production unless your host has intentional persistent disk.
PAYLOAD_ALLOW_PRODUCTION_SQLITE="false"

# Keep schema auto-push off in production unless you are in a controlled migration window.
PAYLOAD_AUTO_PUSH_SCHEMA="false"
