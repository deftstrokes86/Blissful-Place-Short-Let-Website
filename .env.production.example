# Hostinger production environment template
# Add these values in your Hostinger Node.js app environment variables.
# Save the changes, then use Settings and redeploy.
# For the grouped explanation of what each variable does, see docs/production-env-setup.md.

# Core app runtime
NODE_ENV="production"
SITE_URL="https://www.blissfulplaceresidences.com"
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Prisma / Supabase Postgres
# Recommended default for Hostinger: Supabase Supavisor session pooler on port 5432.
# If direct database connectivity from Hostinger is confirmed, you may use the direct host instead.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Optional only for local Prisma migrate workflows.
# Most production deployments should leave this blank.
SHADOW_DATABASE_URL=""

# Payload CMS database
# Public /blog and /blog/[slug] reads use this same Payload database path in production.
# Normal setup: leave this blank so Payload reuses DATABASE_URL.
# If you intentionally set PAYLOAD_DATABASE_URL in production, it should usually be the same Supabase Postgres value as DATABASE_URL.
PAYLOAD_DATABASE_URL=""
PAYLOAD_AUTO_PUSH_SCHEMA="false"

# Payload media / Supabase Storage
PAYLOAD_MEDIA_SUPABASE_BUCKET="blog-media"
PAYLOAD_MEDIA_SUPABASE_REGION="your-storage-region"
PAYLOAD_MEDIA_SUPABASE_PROJECT_REF="your-project-ref"
PAYLOAD_MEDIA_SUPABASE_ENDPOINT=""
PAYLOAD_MEDIA_SUPABASE_ACCESS_KEY_ID="replace-with-supabase-storage-access-key"
PAYLOAD_MEDIA_SUPABASE_SECRET_ACCESS_KEY="replace-with-supabase-storage-secret-key"
PAYLOAD_MEDIA_SUPABASE_FORCE_PATH_STYLE="true"
PAYLOAD_ALLOW_PRODUCTION_LOCAL_MEDIA="false"

# Feature-specific production secrets such as Flutterwave or email provider credentials
# should be added from .env.example when those features are enabled in production.

