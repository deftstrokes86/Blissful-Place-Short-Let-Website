generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  draft
  pending_online_payment
  pending_transfer_submission
  awaiting_transfer_verification
  pending_pos_coordination
  confirmed
  expired
  cancelled
  failed_payment
}

enum PaymentMethod {
  website
  transfer
  pos
}

enum AuthRole {
  admin
  staff
}

enum PaymentAttemptOutcome {
  pending
  success
  failed
  cancelled
}

enum TransferVerificationStatus {
  pending
  verified
  rejected
  expired
}

enum PosCoordinationStatus {
  requested
  completed
  cancelled
}

enum AvailabilityBlockSourceType {
  reservation
  manual
}

enum AvailabilityBlockType {
  hard_block
  soft_hold
}

enum AvailabilityBlockStatus {
  active
  released
}

enum ManualAvailabilityBlockType {
  maintenance
  owner_blackout
  admin_block
}

enum InventoryItemCategory {
  asset
  consumable
  maintenance_supply
}

enum InventoryItemCriticality {
  critical
  important
  minor
}

enum FlatInventoryConditionStatus {
  ok
  missing
  damaged
  needs_replacement
}

enum StockMovementType {
  add
  deduct
  consume
  adjust
  damage
  replace
  transfer
}

enum ReadinessComponentStatus {
  ready
  attention_required
  blocked
}

enum FlatReadinessStatus {
  ready
  needs_attention
  out_of_service
}

enum InventoryAlertType {
  low_stock
  missing_required_item
  damaged_critical_asset
  readiness_issue
  readiness_impacting_issue
}

enum InventoryAlertSeverity {
  critical
  important
  minor
}

enum InventoryAlertStatus {
  open
  acknowledged
  resolved
}

enum MaintenanceIssueStatus {
  open
  in_progress
  resolved
  closed
}

enum WorkerTaskType {
  restock
  maintenance
  readiness
  inspection
}

enum WorkerTaskPriority {
  critical
  important
  minor
}

enum WorkerTaskStatus {
  pending
  in_progress
  completed
  blocked
  escalated
  open
  cancelled
}

enum WorkerTaskSourceType {
  alert
  maintenance_issue
  readiness
  manual
}

enum NotificationChannel {
  email
  internal
}

enum NotificationAudience {
  guest
  staff
}

enum NotificationStatus {
  pending
  sent
  failed
}

enum TourAppointmentStatus {
  booked
  cancelled
}

model Flat {
  id                   String              @id
  name                 String
  nightlyRate          Int
  maxGuests            Int
  reservations         Reservation[]
  availabilityBlocks   AvailabilityBlock[]
  inventoryAssignments FlatInventory[]
  stockMovements       StockMovement[]
  readiness            FlatReadiness?
  inventoryAlerts      InventoryAlert[]
  maintenanceIssues    MaintenanceIssue[]
  workerTasks          WorkerTask[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Extra {
  id           String             @id
  title        String
  flatFee      Int
  reservations ReservationExtra[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Reservation {
  id                         String                         @id @default(cuid())
  token                      String                         @unique
  status                     ReservationStatus              @default(draft)
  paymentMethod              PaymentMethod?
  draftCurrentStep           Int?
  draftActiveBranch          PaymentMethod?
  flatId                     String
  flat                       Flat                           @relation(fields: [flatId], references: [id], onDelete: Restrict)
  checkIn                    DateTime
  checkOut                   DateTime
  guests                     Int
  guestFirstName             String?
  guestLastName              String?
  guestEmail                 String?
  guestPhone                 String?
  guestSpecialRequests       String?
  currency                   String                         @default("NGN")
  nightlyRate                Int?
  nights                     Int?
  staySubtotal               Int?
  extrasSubtotal             Int                            @default(0)
  estimatedTotal             Int?
  transferHoldStartedAt      DateTime?
  transferHoldExpiresAt      DateTime?
  inventoryReopenedAt        DateTime?
  lastAvailabilityCheckpoint String?
  lastAvailabilityCheckedAt  DateTime?
  lastAvailabilityVersion    String?
  lastAvailabilityPassed     Boolean?
  confirmedAt                DateTime?
  cancelledAt                DateTime?
  extras                     ReservationExtra[]
  paymentAttempts            PaymentAttempt[]
  transferVerifications      TransferVerificationMetadata[]
  posCoordinations           PosCoordinationMetadata[]
  idempotencyKeys            IdempotencyKey[]
  notifications              ReservationNotification[]
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  lastTouchedAt              DateTime                       @default(now())

  @@index([status])
  @@index([paymentMethod])
  @@index([transferHoldExpiresAt])
  @@index([flatId, checkIn, checkOut])
}

model AvailabilityBlock {
  id              String                      @id @default(cuid())
  flatId          String
  flat            Flat                        @relation(fields: [flatId], references: [id], onDelete: Restrict)
  sourceType      AvailabilityBlockSourceType
  sourceId        String
  blockType       AvailabilityBlockType
  manualBlockType ManualAvailabilityBlockType?
  startDate       DateTime                    @db.Date
  endDate         DateTime                    @db.Date
  reason          String?
  notes           String?
  createdBy       String?
  status          AvailabilityBlockStatus     @default(active)
  expiresAt       DateTime?
  releasedAt      DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@unique([sourceType, sourceId])
  @@index([flatId, status, startDate, endDate])
  @@index([expiresAt])
}

model InventoryItem {
  id                String                    @id @default(cuid())
  name              String
  category          InventoryItemCategory
  internalCode      String?                   @unique
  unitOfMeasure     String
  reorderThreshold  Int?
  parLevel          Int?
  criticality       InventoryItemCriticality  @default(important)
  templateItems     TemplateItem[]
  flatInventory     FlatInventory[]
  stockMovements    StockMovement[]
  inventoryAlerts   InventoryAlert[]
  maintenanceIssues MaintenanceIssue[]
  centralStock      CentralStock?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([category])
  @@index([criticality])
}

model InventoryTemplate {
  id            String         @id @default(cuid())
  name          String
  description   String?
  flatType      String?
  templateItems TemplateItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model TemplateItem {
  id              String            @id @default(cuid())
  templateId      String
  template        InventoryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  expectedQuantity Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([templateId])
  @@index([inventoryItemId])
  @@unique([templateId, inventoryItemId])
}

model FlatInventory {
  id               String                       @id @default(cuid())
  flatId           String
  flat             Flat                         @relation(fields: [flatId], references: [id], onDelete: Restrict)
  inventoryItemId  String
  inventoryItem    InventoryItem                @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  expectedQuantity Int
  currentQuantity  Int
  conditionStatus  FlatInventoryConditionStatus @default(ok)
  notes            String?
  lastCheckedAt    DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([flatId])
  @@index([inventoryItemId])
  @@unique([flatId, inventoryItemId])
}

model StockMovement {
  id              String            @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  flatId          String?
  flat            Flat?             @relation(fields: [flatId], references: [id], onDelete: SetNull)
  movementType    StockMovementType
  quantity        Int
  reason          String
  notes           String?
  actorId         String?
  createdAt       DateTime          @default(now())

  @@index([inventoryItemId, createdAt])
  @@index([flatId, createdAt])
}

model FlatReadiness {
  flatId              String                   @id
  flat                Flat                     @relation(fields: [flatId], references: [id], onDelete: Cascade)
  cleaningStatus      ReadinessComponentStatus @default(attention_required)
  linenStatus         ReadinessComponentStatus @default(attention_required)
  consumablesStatus   ReadinessComponentStatus @default(attention_required)
  maintenanceStatus   ReadinessComponentStatus @default(attention_required)
  criticalAssetStatus ReadinessComponentStatus @default(attention_required)
  readinessStatus     FlatReadinessStatus      @default(needs_attention)
  overrideStatus      FlatReadinessStatus?
  overrideReason      String?
  updatedAt           DateTime                 @updatedAt
}

model InventoryAlert {
  id              String               @id @default(cuid())
  inventoryItemId String?
  inventoryItem   InventoryItem?       @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  flatId          String?
  flat            Flat?                @relation(fields: [flatId], references: [id], onDelete: SetNull)
  alertType       InventoryAlertType
  severity        InventoryAlertSeverity
  status          InventoryAlertStatus @default(open)
  message         String
  createdAt       DateTime             @default(now())
  resolvedAt      DateTime?

  @@index([status, severity, createdAt])
  @@index([flatId])
  @@index([inventoryItemId])
}

model MaintenanceIssue {
  id              String                 @id @default(cuid())
  flatId          String
  flat            Flat                   @relation(fields: [flatId], references: [id], onDelete: Restrict)
  inventoryItemId String?
  inventoryItem   InventoryItem?         @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  title           String
  notes           String?
  severity        InventoryAlertSeverity
  status          MaintenanceIssueStatus @default(open)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  resolvedAt      DateTime?

  @@index([flatId, status, createdAt])
  @@index([inventoryItemId])
}

model ReservationExtra {
  reservationId String
  extraId       String
  appliedFlatFee Int
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  extra         Extra       @relation(fields: [extraId], references: [id], onDelete: Restrict)

  @@id([reservationId, extraId])
  @@index([extraId])
}

model PaymentAttempt {
  id                String                @id @default(cuid())
  reservationId     String
  reservation       Reservation           @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethod
  provider          String
  outcome           PaymentAttemptOutcome @default(pending)
  amount            Int
  currency          String                @default("NGN")
  providerReference String?
  idempotencyKey    String
  metadata          Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([reservationId, createdAt])
  @@index([provider, providerReference])
  @@index([idempotencyKey])
}

model TransferVerificationMetadata {
  id                 String                     @id @default(cuid())
  reservationId      String
  reservation        Reservation                @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  transferReference  String
  proofNote          String
  proofReceivedAt    DateTime
  verificationStatus TransferVerificationStatus @default(pending)
  verifiedByStaffId  String?
  verifiedAt         DateTime?
  verificationNote   String?
  idempotencyKey     String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([reservationId, createdAt])
  @@index([verificationStatus])
  @@index([idempotencyKey])
}

model PosCoordinationMetadata {
  id                 String                @id @default(cuid())
  reservationId      String
  reservation        Reservation           @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  contactWindow      String
  coordinationNote   String?
  status             PosCoordinationStatus @default(requested)
  requestedAt        DateTime
  completedAt        DateTime?
  completedByStaffId String?
  idempotencyKey     String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([reservationId, requestedAt])
  @@index([status])
  @@index([idempotencyKey])
}

model IdempotencyKey {
  key              String
  action           String
  reservationId    String?
  reservation      Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  payloadHash      String
  responseSnapshot Json
  createdAt        DateTime     @default(now())
  expiresAt        DateTime?

  @@id([key, action])
  @@index([reservationId])
  @@index([createdAt])
}

model AuthUser {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         AuthRole
  isActive     Boolean       @default(true) @map("is_active")
  sessions     AuthSession[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique @map("session_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model WorkerTask {
  id          String               @id @default(cuid())
  flatId      String
  flat        Flat                 @relation(fields: [flatId], references: [id], onDelete: Restrict)
  title       String
  description String?
  taskType    WorkerTaskType
  priority    WorkerTaskPriority
  status      WorkerTaskStatus     @default(pending)
  sourceType  WorkerTaskSourceType
  sourceId    String
  assignedTo  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  completedAt DateTime?

  @@index([flatId, status, createdAt])
  @@index([sourceType, sourceId])
}

model ReservationNotification {
  id               String               @id @default(cuid())
  eventType        String
  templateKey      String
  audience         NotificationAudience
  channel          NotificationChannel
  recipient        String
  title            String
  body             String?
  templateRef      String?
  status           NotificationStatus   @default(pending)
  dedupeKey        String               @unique
  payload          Json
  reservationId    String?
  reservation      Reservation?         @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  reservationToken String?
  paymentAttemptId String?
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([reservationId, createdAt])
  @@index([status])
}

model TourAppointment {
  id         String                @id @default(cuid())
  date       DateTime              @db.Date
  time       String
  guestName  String
  guestEmail String
  guestPhone String?
  status     TourAppointmentStatus @default(booked)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([date, time, status])
}

model CentralStock {
  inventoryItemId String        @id
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Int           @default(0)
  updatedAt       DateTime      @updatedAt
}
