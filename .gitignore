# Dependencies
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js and build output
/.next/
/out/
/build/
/dist/
/coverage/
/.turbo/
/.vercel/

# Runtime temp output and local test builds
/.tmp/
/.tmp-*/
/.tmp-test-build/
/test-results/
*.tmp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example
!.env.production.example

# Local databases and generated Prisma state
/.data/
/.prisma/
/prisma/*.db
/prisma/*.db-*
/prisma/*.sqlite
/prisma/*.sqlite3

# Payload local uploads and generated media
# Note: this repo intentionally keeps /media tracked because legacy blog
# migration assets live there. Ignore runtime-only upload directories instead.
/uploads/
/public/uploads/

# IDE files
/.idea/
/.vscode/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Misc local artifacts
*.pem
*.tsbuildinfo
next-env.d.ts
